        "@remixicon/react": "^4.9.0",
        "@stoprocent/noble": "^2.3.10",
        "bun-plugin-tailwind": "^0.1.2",
        "class-variance-authority": "^0.7.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "shadcn": "^3.8.4",
